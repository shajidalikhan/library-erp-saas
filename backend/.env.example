# ==========================================================
# LIBRARY ERP - BACKEND ENVIRONMENT (EXAMPLE)
# ==========================================================
# Copy this file to `.env` and fill real values for your environment.

NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ----- MongoDB -----
MONGODB_URI=mongodb+srv://rohitkumarjnv25:rohit25@CLUSTER.mongodb.net/library_erp?retryWrites=true&w=majority
MONGODB_DB_NAME=library_erp

# ----- JWT -----
JWT_ACCESS_SECRET=library_erp_access_secret_super_secure_2026
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=library_erp_refresh_secret_super_secure_2026
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=library-erp
JWT_AUDIENCE=library-erp-client

# ----- Cookies (local) -----
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ----- Cookies (Vercel frontend + Render API — cross-origin) -----
# COOKIE_DOMAIN=
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none

# ----- CORS -----
CORS_ORIGINS=http://localhost:3000
# Production example (comma-separated, no trailing slashes):
# CORS_ORIGINS=https://library-erp-saas.vercel.app
# Temporary: allow any Origin while debugging (disable after CORS_ORIGINS is set)
# CORS_RELAXED=true

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# ----- Security -----
BCRYPT_SALT_ROUNDS=12

# ----- Logging -----
LOG_LEVEL=info

# ----- Notifications (optional cron) -----
# When true, registers daily reminder jobs (payment due, overdue, membership expiry).
NOTIFICATION_JOBS_ENABLED=false

# ----- Attendance auto-checkout -----
AUTO_CHECKOUT_ENABLED=true
AUTO_CHECKOUT_GRACE_MINUTES=30
ATTENDANCE_LATE_GRACE_MINUTES=15

# ----- Frontend / Email -----
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=https://library-erp-saas.vercel.app

# Hostinger business email (see docs/email-hostinger-setup.md)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=library@codeofwishes.com
SMTP_PASS=123Roh@25
SMTP_FROM="Library ERP <library@codeofwishes.com>"

# ----- Cloudinary (file uploads — see docs/cloudinary-upload-setup.md) -----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=library-erp

# ----- Razorpay (public booking online payment placeholder) -----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PUBLIC_BOOKING_HOLD_HOURS=3
